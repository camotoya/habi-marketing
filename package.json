{
  "name": "habi-marketing",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "lint": "turbo lint",
    "dev:home": "turbo dev --filter=@habi/home",
    "dev:sellers": "turbo dev --filter=@habi/sellers",
    "dev:buyers": "turbo dev --filter=@habi/buyers",
    "build:home": "turbo build --filter=@habi/home",
    "build:sellers": "turbo build --filter=@habi/sellers",
    "build:buyers": "turbo build --filter=@habi/buyers"
  },
  "devDependencies": {
    "turbo": "^2.9.5"
  }
}
